# Banco de Dados (Supabase)
DB_CONNECTION="Host=aws-0-us-west-2.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.USERNAME-AQUI;Password=SENHA-AQUI"

# Chave secreta para o Token JWT
JWT_KEY=SENHA_JWT

# RabbitMQ
RABBITMQ_HOST= HOST #(Está default)
RABBITMQ_PORT= PORT #(Está default)
RABBITMQ_USER= USER #(Está default)
RABBITMQ_PASS= PASS #(Está default)

# Configurações de API
ASPNETCORE_ENVIRONMENT=Development
PORT_BACKEND= PORT_BACKEND
PORT_FRONTEND= PORT_FRONTEND